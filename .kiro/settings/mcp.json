{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--isolated"
      ],
      "disabled": true,
      "autoApprove": [
        "browser_navigate",
        "browser_click",
        "browser_fill_form",
        "browser_wait_for",
        "browser_take_screenshot",
        "browser_snapshot",
        "browser_type",
        "browser_press_key",
        "browser_close",
        "browser_run_code",
        "browser_handle_dialog"
      ]
    }
  }
}